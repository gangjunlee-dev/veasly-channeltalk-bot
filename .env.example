# VEASLY ChannelTalk Bot - environment variables
# Copy this file to .env and fill in real values. Never commit the real .env.

# ChannelTalk Open API
CHANNEL_ACCESS_KEY=
CHANNEL_ACCESS_SECRET=

# Server
PORT=3000

# AI - Gemini + Pinecone
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
AI_ENABLED=true

# Veasly backend API
VEASLY_API_TOKEN=
VEASLY_API_URL=

# Dashboard basic-auth
DASHBOARD_USER=
DASHBOARD_PASS=

# Cloudflare Workers auto-update
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_WORKER_NAME=
CF_KV_NAMESPACE_ID=

# Email notifications
EMAIL_USER=
EMAIL_PASS=
